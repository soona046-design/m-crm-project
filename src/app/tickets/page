  // 단축키 처리 - 임시로 비활성화 (네비게이션 문제 해결)
  // TODO: 나중에 단축키가 필요하면 다시 활성화하되, 브라우저 기본 동작을 방해하지 않도록 수정
  /*
  useEffect(() => {
    const handleKeyDown = (event: KeyboardEvent) => {
      if (event.ctrlKey || event.metaKey) { // Ctrl 또는 Cmd 키와 함께
